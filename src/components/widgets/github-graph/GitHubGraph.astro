---
// GitHub 贡献热力图组件
---

<div id="github-graph" class="my-6 flex justify-center">
  <p>加载 GitHub 贡献图中...</p>
</div>

<script>
  import { GitHubContributionWidget } from "github-contrib-graph";

  const container = document.getElementById("github-graph");
  if (container) {
    const widget = new GitHubContributionWidget({
      username: "ziddzide",
      container,
      months: 12,
    });
    widget.render();
  }
</script>
