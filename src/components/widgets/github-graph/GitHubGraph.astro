---
// GitHub 贡献热力图组件
---

<div id="github-graph" class="my-6 flex justify-center">
  <p>加载 GitHub 贡献图中...</p>
</div>

<script>
  import { GitHubContributionWidget } from "github-contrib-graph";

  function initGitHubGraph() {
    const container = document.getElementById("github-graph");
    if (!container || container.dataset.loaded) return;
    container.dataset.loaded = "true";
    const widget = new GitHubContributionWidget({
      username: "ziddzide",
      container,
      months: 12,
    });
    widget.render();
  }

  // 首次加载
  initGitHubGraph();

  // Swup 页面切换后重新初始化
  document.addEventListener("swup:contentReplaced", initGitHubGraph);
  document.addEventListener("mizuki:page:loaded", initGitHubGraph);
</script>
