{
  "name": "oddmisc",
  "version": "1.2.8",
  "description": "杂七杂八奇怪小工具 npm 包 — Umami 分享链接统计读取与 Astro 集成",
  "homepage": "https://github.com/yCENzh/oddmisc#readme",
  "bugs": {
    "url": "https://github.com/yCENzh/oddmisc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yCENzh/oddmisc.git"
  },
  "author": "yCENzh",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./astro": {
      "types": "./dist/astro/index.d.ts",
      "import": "./dist/astro/index.js",
      "require": "./dist/astro/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup --clean",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "umami",
    "analytics",
    "statistics",
    "web-analytics",
    "visitor-tracking",
    "utilities",
    "tools"
  ],
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "astro": "^6.4.8",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
